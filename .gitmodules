[submodule ".registry"]
	path = .registry
	url = https://github.com/viralemergence/viralemergence.r-universe.dev
	branch = HEAD
[submodule "epizootic"]
	path = epizootic
	url = https://github.com/viralemergence/epizootic
[submodule "insectDisease"]
	path = insectDisease
	url = https://github.com/viralemergence/insectDisease
[submodule "virionData"]
	path = virionData
	url = https://github.com/viralemergence/virionData
[submodule "wddsWizard"]
	path = wddsWizard
	url = https://github.com/viralemergence/wddsWizard
